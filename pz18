#!/bin/bash

# PRACTICE18

if [ "$#" -lt 2 ]; then
    echo "Error: not enough arguments."
    echo "Usage: $0 <destination_dir> <file1> [file2 ...]"
    exit 1
fi

DEST_DIR="$1"
shift

if [ -e "$DEST_DIR" ]; then
    echo "Error: destination directory '$DEST_DIR' already exists."
    exit 1
fi

mkdir -p "$DEST_DIR"

count=1
for file in "$@"; do
    if [ ! -f "$file" ]; then
        echo "Error: file '$file' not found. Skipping."
        continue
    fi
    
    cp "$file" "$DEST_DIR/video-$count.mp4"
    count=$((count + 1))
done

echo "Archive successfully created in '$DEST_DIR'."

echo -e "\n=== Control Questions Answers ==="
cat << 'EOF'
1. What loop types does Bash support?
Ans: for, while, and until.

2. Difference between while and until?
Ans: 'while' runs as long as condition is true. 'until' runs as long as condition is false.

3. Basic syntax of 'for' loop?
Ans: for i in 1 2 3 4 5; do echo $i; done

4. Command to exit a loop immediately?
Ans: break

5. Command to skip to the next iteration?
Ans: continue

6. Example of while loop counting 0 to 9?
Ans:
counter=0
while [ $counter -lt 10 ]; do
    echo $counter
    counter=$((counter + 1))
done

7. How to iterate over command output?
Ans: for file in $(ls *.txt); do echo "$file"; done

8. How does C-style for loop work in Bash?
Ans: using double parentheses: for (( i=0; i<10; i++ )); do echo $i; done

9. What if 'until' condition is initially true?
Ans: The loop body will not execute at all.

10. How to process command line arguments in a loop?
Ans: for arg in "$@"; do echo "$arg"; done
EOF
